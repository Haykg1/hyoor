{
  "name": "@repo/shared",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./dist/constants/index.js"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./dist/utils/index.js"
    },
    "./dto": {
      "types": "./src/dto/index.ts",
      "default": "./dist/dto/index.js"
    },
    "./property-types": {
      "types": "./src/property-types.ts",
      "default": "./dist/property-types.js"
    },
    "./data/yerevan-metro-stations.json": "./src/data/yerevan-metro-stations.json",
    "./data/yerevan_pois.json": "./src/data/yerevan_pois.json",
    "./data/armenia_pois.json": "./src/data/armenia_pois.json",
    "./data/poi-datasets": {
      "types": "./src/data/poi-datasets.ts",
      "default": "./dist/data/poi-datasets.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@repo/prettier-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "prettier": "@repo/prettier-config"
}
