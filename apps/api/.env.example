NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/appdb
FRONTEND_URL=http://localhost:3000

# AWS S3 (LocalStack: AWS_ENDPOINT_URL=http://localhost:4566, test/test credentials)
AWS_REGION=eu-central-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_PROPERTIES_BUCKET=properties
AWS_S3_AVATARS_BUCKET=avatars

# JWT (min 32 characters each)
JWT_SECRET=change_me_min_32_chars_long_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Mail — leave RESEND_API_KEY empty to log emails to console (dev fallback)
MAIL_FROM=RentStar <noreply@rentstar.am>
RESEND_API_KEY=

# Apple OAuth (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Redis (POI GEO cache)
REDIS_URL=redis://localhost:6379

# Security (optional — defaults shown)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=100
# THROTTLE_AUTH_LIMIT=10
# THROTTLE_WRITE_LIMIT=30
# THROTTLE_PAYMENTS_LIMIT=10
# THROTTLE_MESSAGING_LIMIT=60
# THROTTLE_GEOCODING_LIMIT=30
# YANDEX_MAPS_API_KEY=
# TRUST_PROXY=false
# JSON_BODY_LIMIT=10mb
# MAX_UPLOAD_BYTES=5242880
